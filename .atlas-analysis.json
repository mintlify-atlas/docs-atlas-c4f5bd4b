  "keyFeatures": [
    "JWT-based authentication with role-based access control (USUARIO and SOPORTE roles)",
    "Ticket lifecycle management: create, list, update status, and track history",
    "Automated email notifications via SMTP (ticket confirmation, status updates, and resolution alerts)",
    "Microsoft SQL Server integration with connection pooling",
    "Support team code verification for privileged role registration",
    "Public ticket lookup by ID without authentication"
  ],
  "publicApiSurface": [
    "POST /auth/register",
    "POST /auth/login",
    "GET /api/public/departamentos",
    "GET /api/public/tickets/:idTicket",
    "GET /api/admin/tickets",
    "POST /api/admin/tickets",
    "PUT /api/admin/tickets/:id/estado",
    "GET /api/admin/tickets/historial"
  ]
